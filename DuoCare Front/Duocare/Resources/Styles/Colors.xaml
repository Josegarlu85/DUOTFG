<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Fondo general -->
    <Color x:Key="BackgroundPrimary">#050B12</Color>

    <!-- Tarjetas -->
    <Color x:Key="CardBackground">#0D1622</Color>
    <Color x:Key="CardSecondary">#112233</Color>

    <!-- Texto -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#A0AEC0</Color>
    <Color x:Key="TextMuted">#D0D0D0</Color>

    <!-- Botones -->
    <Color x:Key="ButtonPrimary">#7FB3D5</Color>
    <Color x:Key="ButtonDanger">#D57F7F</Color>

    <!-- Iconos -->
    <Color x:Key="IconPrimary">#7FB3D5</Color>

    <!-- Bordes -->
    <Color x:Key="BorderSoft">#1A2633</Color>

</ResourceDictionary>
