<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Duocare.ViewModels"
    BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.BindingContext>
        <vm:SettingsViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="24" Spacing="24">

        <Label Text="Ajustes"
               FontSize="32"
               FontAttributes="Bold"
               TextColor="{StaticResource TextPrimary}" />

        <Frame CornerRadius="20"
               Padding="20"
               BackgroundColor="{StaticResource CardBackground}"
               HasShadow="True">

            <VerticalStackLayout Spacing="24">

                <!-- Notificaciones -->
                <HorizontalStackLayout Spacing="12">
                    <Label Text="Notificaciones"
                           FontSize="18"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalOptions="Center" />
                    <Switch IsToggled="{Binding NotificationsEnabled}" />
                </HorizontalStackLayout>

                <BoxView HeightRequest="1"
                         BackgroundColor="{StaticResource DividerColor}"
                         Margin="0,10,0,0"/>

                <Label Text="Gestión de cuenta"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <VerticalStackLayout Spacing="12">

                    <Button Text="Cambiar contraseña"
                            Command="{Binding ChangePasswordCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="12" />

                    <Button Text="Cambiar correo"
                            Command="{Binding ChangeEmailCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="12" />

                    <Button Text="Cambiar nombre"
                            Command="{Binding ChangeNameCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="12" />

                    <Button Text="Cambiar foto de perfil"
                            Command="{Binding ChangeProfilePhotoCommand}"
                            BackgroundColor="{StaticResource ButtonSecondary}"
                            TextColor="{StaticResource TextPrimary}"
                            CornerRadius="12" />

                </VerticalStackLayout>

            </VerticalStackLayout>

        </Frame>

    </VerticalStackLayout>

</ContentPage>
