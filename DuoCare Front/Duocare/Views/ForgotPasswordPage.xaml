<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Duocare.ViewModels"
    BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.BindingContext>
        <vm:ForgotPasswordViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Recuperar contraseña"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               TextColor="{StaticResource TextPrimary}" />

        <Frame BackgroundColor="{StaticResource CardBackground}"
               CornerRadius="14"
               Padding="12">

            <Entry Placeholder="Introduce tu correo"
                   Text="{Binding Email}"
                   Keyboard="Email"
                   PlaceholderColor="{StaticResource TextSecondary}"
                   TextColor="{StaticResource TextPrimary}" />
        </Frame>

        <Button Text="Enviar correo de recuperación"
                HeightRequest="50"
                CornerRadius="14"
                TextColor="White"
                BackgroundColor="{StaticResource ButtonPrimary}"
                Command="{Binding SendRecoveryEmailCommand}" />

    </VerticalStackLayout>

</ContentPage>
