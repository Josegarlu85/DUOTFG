<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.ChangePasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Duocare.ViewModels"
    BackgroundColor="{StaticResource BackgroundPrimary}"
    Shell.NavBarIsVisible="True">

    <!-- ⭐ Habilitar flecha atrás -->
    <Shell.BackButtonBehavior IsEnabled="True" />

    <ContentPage.BindingContext>
        <vm:ChangePasswordViewModel />
    </ContentPage.BindingContext>

    <VerticalStackLayout Padding="24" Spacing="24">

        <Label Text="Cambiar contraseña"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="{StaticResource TextPrimary}" />

        <Frame CornerRadius="20"
               Padding="20"
               BackgroundColor="{StaticResource CardBackground}"
               HasShadow="True">

            <VerticalStackLayout Spacing="16">

                <!-- CONTRASEÑA ACTUAL -->
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Entry Placeholder="Contraseña actual"
                           IsPassword="{Binding IsCurrentPasswordHidden}"
                           Text="{Binding CurrentPassword}" />

                    <Label Grid.Column="1"
                           Text="{Binding CurrentPasswordEmoji}"
                           FontSize="22"
                           VerticalOptions="Center"
                           Padding="10">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleCurrentPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- NUEVA CONTRASEÑA -->
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Entry Placeholder="Nueva contraseña"
                           IsPassword="{Binding IsNewPasswordHidden}"
                           Text="{Binding NewPassword}" />

                    <Label Grid.Column="1"
                           Text="{Binding NewPasswordEmoji}"
                           FontSize="22"
                           VerticalOptions="Center"
                           Padding="10">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleNewPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- INDICADOR DE FORTALEZA -->
                <Label Text="{Binding PasswordStrengthText}"
                       TextColor="{Binding PasswordStrengthColor}"
                       FontSize="14"
                       IsVisible="{Binding ShowStrength}" />

                <!-- CONFIRMAR CONTRASEÑA -->
                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                    <Entry Placeholder="Confirmar nueva contraseña"
                           IsPassword="{Binding IsConfirmPasswordHidden}"
                           Text="{Binding ConfirmPassword}" />

                    <Label Grid.Column="1"
                           Text="{Binding ConfirmPasswordEmoji}"
                           FontSize="22"
                           VerticalOptions="Center"
                           Padding="10">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- ERRORES -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       FontSize="14"
                       IsVisible="{Binding HasError}" />

                <!-- BOTÓN GUARDAR -->
                <Button Text="Guardar cambios"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="{StaticResource ButtonPrimary}"
                        TextColor="White"
                        CornerRadius="12" />

            </VerticalStackLayout>

        </Frame>

    </VerticalStackLayout>

</ContentPage>
