<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.CitasPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Duocare.ViewModels"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    BackgroundColor="#050B12"
    Title="Citas">

    <ContentPage.BindingContext>
        <vm:AppointmentsViewModel />
    </ContentPage.BindingContext>

    <!-- ✅ GRID PROPORCIONAL -->
    <Grid Padding="18"
          RowSpacing="12"
          RowDefinitions="Auto,Auto,2*,Auto,1*">

        <!-- TÍTULO -->
        <Label Grid.Row="0"
               Text="📍 Citas"
               FontSize="30"
               FontAttributes="Bold"
               TextColor="White" />

        <!-- FORMULARIO -->
        <Frame Grid.Row="1"
               BackgroundColor="#112233"
               CornerRadius="18"
               Padding="14">

            <VerticalStackLayout Spacing="10">

                <Entry Placeholder="Título (ej: Entrega, Recogida, Reunión...)"
                       Text="{Binding Title}"
                       TextColor="White"
                       PlaceholderColor="#8899AA"/>

                <!-- ✅ FECHA Y HORA ARREGLADAS -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">

                    <DatePicker Grid.Column="0"
                                Date="{Binding Date}"
                                TextColor="White" />

                    <TimePicker Grid.Column="1"
                                Time="{Binding Time}"
                                Format="HH:mm"
                                TextColor="White" />

                </Grid>

                <Editor Placeholder="Notas (opcional)"
                        Text="{Binding Notes}"
                        TextColor="White"
                        PlaceholderColor="#8899AA"
                        AutoSize="TextChanges"/>

                <Label Text="{Binding SelectedLocationText}"
                       TextColor="#D0D0D0"
                       LineBreakMode="WordWrap"/>

            </VerticalStackLayout>
        </Frame>

        <!-- ✅ MAPA (PROPORCIÓN 2x, ESTABLE) -->
        <Frame Grid.Row="2"
               BackgroundColor="#0D1622"
               CornerRadius="18"
               Padding="0"
               HasShadow="True">

            <mapsui:MapView x:Name="Map" />

        </Frame>

        <!-- BOTÓN -->
        <Button Grid.Row="3"
                Text="Guardar cita"
                Command="{Binding SaveCommand}"
                BackgroundColor="#7FB3D5"
                TextColor="Black"
                CornerRadius="14"
                HeightRequest="48"/>

        <!-- ✅ LISTA (PROPORCIÓN 1x, SCROLL INTERNO) -->
        <CollectionView Grid.Row="4"
                        ItemsSource="{Binding Appointments}">

            <CollectionView.EmptyView>
                <Label Text="No hay citas guardadas todavía."
                       TextColor="#A0AEC0"
                       HorizontalOptions="Center"
                       Margin="0,10"/>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#112233"
                           CornerRadius="16"
                           Padding="14"
                           Margin="0,8"
                           HasShadow="True">

                        <VerticalStackLayout Spacing="8">

                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <Label Text="{Binding Date, StringFormat='Fecha: {0:dd/MM/yyyy}'}"
                                   TextColor="#D0D0D0"/>

                            <Label Text="{Binding Time, StringFormat='Hora: {0:HH\\:mm}'}"
                                   TextColor="#D0D0D0"/>

                            <Label Text="{Binding LocationText}"
                                   TextColor="#D0D0D0"/>

                            <Button Text="Eliminar"
                                    BackgroundColor="#FF6B6B"
                                    TextColor="White"
                                    CornerRadius="12"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AppointmentsViewModel}}, Path=DeleteCommand}"
                                    CommandParameter="{Binding .}"/>

                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>