<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Duocare.ViewModels"
    BackgroundColor="{StaticResource BackgroundPrimary}">

    <ContentPage.BindingContext>
        <vm:DashboardViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="28">

            <!-- TÍTULO PRINCIPAL -->
            <Label Text="Duocare"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />

            <Label Text="Coordina cuidados compartidos con claridad y respeto."
                   FontSize="16"
                   TextColor="{StaticResource TextSecondary}"
                   Margin="0,-10,0,10" />

            <!-- TARJETA PRINCIPAL -->
            <Frame BackgroundColor="{StaticResource CardBackground}"
                   CornerRadius="18"
                   Padding="20"
                   HasShadow="True">

                <!-- ⭐⭐ BLOQUE PREMIUM FORZADO ⭐⭐ -->
                <VerticalStackLayout Spacing="26">

                    <!-- TÍTULO + BOTÓN AÑADIR -->
                    <HorizontalStackLayout HorizontalOptions="Fill" VerticalOptions="Center">

                        <Label Text="Notas importantes"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               HorizontalOptions="StartAndExpand" />

                        <!-- ⭐ BOTÓN + MEDIANO Y FUNCIONAL ⭐ -->
                        <Frame WidthRequest="42"
                               HeightRequest="42"
                               CornerRadius="21"
                               BackgroundColor="#6366F1"
                               Padding="0"
                               HasShadow="True"
                               VerticalOptions="Center"
                               HorizontalOptions="End">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding AddNoteCommand}" />
                            </Frame.GestureRecognizers>

                            <Label Text="+"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>

                    </HorizontalStackLayout>

                    <!-- LISTA DE NOTAS -->
                    <CollectionView x:Name="NotesCollection"
                                    ItemsSource="{Binding Notes}"
                                    SelectionMode="None">

                        <CollectionView.ItemTemplate>
                            <DataTemplate>

                                <!-- ⭐ FRAME DE LA NOTA CON ANIMACIÓN DESDE C# ⭐ -->
                                <Frame x:Name="AnimatedNote"
                                       BackgroundColor="#111827"
                                       CornerRadius="22"
                                       Padding="24"
                                       Margin="0,14"
                                       HasShadow="True">

                                    <Frame.Shadow>
                                        <Shadow Brush="#00000066"
                                                Offset="0,8"
                                                Radius="18"
                                                Opacity="0.55" />
                                    </Frame.Shadow>

                                    <VerticalStackLayout Spacing="20">

                                        <!-- CONTENIDO DE LA NOTA -->
                                        <HorizontalStackLayout Spacing="20">

                                            <Label FontSize="30"
                                                   VerticalOptions="Center"
                                                   Text="{Binding IsDone, Converter={StaticResource BoolToEmojiConverter}}">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=ToggleNoteCommand}"
                                                        CommandParameter="{Binding}" />
                                                </Label.GestureRecognizers>
                                            </Label>

                                            <Label Text="{Binding Text}"
                                                   TextColor="#E5E7EB"
                                                   FontSize="18"
                                                   LineHeight="1.45"
                                                   Opacity="{Binding IsDone, Converter={StaticResource BoolToOpacityConverter}}" />
                                        </HorizontalStackLayout>

                                        <!-- BOTONES -->
                                        <HorizontalStackLayout Spacing="18">

                                            <Frame Padding="16,10"
                                                   BackgroundColor="#4F46E5"
                                                   CornerRadius="14">
                                                <Label Text="Editar"
                                                       TextColor="White"
                                                       FontSize="15"
                                                       FontAttributes="Bold">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=EditNoteCommand}"
                                                            CommandParameter="{Binding}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Frame>

                                            <Frame Padding="16,10"
                                                   BackgroundColor="#EF4444"
                                                   CornerRadius="14">
                                                <Label Text="Eliminar"
                                                       TextColor="White"
                                                       FontSize="15"
                                                       FontAttributes="Bold">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DashboardViewModel}}, Path=DeleteNoteCommand}"
                                                            CommandParameter="{Binding}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                            </Frame>

                                        </HorizontalStackLayout>

                                    </VerticalStackLayout>

                                </Frame>

                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                    </CollectionView>

                </VerticalStackLayout>
                <!-- ⭐⭐ FIN BLOQUE PREMIUM FORZADO ⭐⭐ -->

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
