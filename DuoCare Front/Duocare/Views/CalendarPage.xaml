<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.CalendarPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:Duocare.ViewModels"
    BackgroundColor="{StaticResource BackgroundPrimary}">

    <!-- ⭐ BINDING CONTEXT -->
    <ContentPage.BindingContext>
        <viewmodels:CalendarViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- TÍTULO -->
            <Label Text="Calendario"
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />

            <!-- FECHA BONITA -->
            <Label Text="{Binding SelectedDateFormatted}"
                   FontSize="20"
                   TextColor="{StaticResource TextSecondary}" />

            <!-- ⭐ DATE PICKER PREMIUM -->
            <Frame BackgroundColor="#1E1E1E"
                   CornerRadius="12"
                   Padding="10"
                   HasShadow="True">
                <DatePicker Date="{Binding SelectedDate}"
                            Format="D"
                            TextColor="White"
                            BackgroundColor="Transparent"
                            FontSize="18"
                            DateSelected="OnDateSelected" />
            </Frame>

            <!-- ========================= -->
            <!--      EVENTOS DE NIÑOS     -->
            <!-- ========================= -->
            <VerticalStackLayout Spacing="12">

                <Label Text="Eventos de niños"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <Button Text="➕ Crear evento de niño"
                        Command="{Binding CreateChildEventCommand}"
                        BackgroundColor="#4A90E2"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="48" />

                <CollectionView ItemsSource="{Binding ChildEvents}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="16"
                                   Padding="16"
                                   BackgroundColor="{StaticResource CardBackground}"
                                   HasShadow="True"
                                   Margin="0,6">

                                <VerticalStackLayout Spacing="8">

                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="👶"
                                               FontSize="24" />
                                        <Label Text="{Binding Title}"
                                               FontSize="18"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="📍"
                                               FontSize="18" />
                                        <Label Text="{Binding Location}"
                                               FontSize="16"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="12">

                                        <Button Text="Ver detalles"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewEventDetailsCommand}"
                                                CommandParameter="{Binding}"
                                                BackgroundColor="#4A90E2"
                                                TextColor="White"
                                                CornerRadius="10"
                                                HeightRequest="40" />

                                        <Button Text="Eliminar"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteEventCommand}"
                                                CommandParameter="{Binding}"
                                                BackgroundColor="#E74C3C"
                                                TextColor="White"
                                                CornerRadius="10"
                                                HeightRequest="40" />

                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <BoxView HeightRequest="1"
                     BackgroundColor="{StaticResource SeparatorColor}"
                     Margin="0,10" />

            <!-- ========================= -->
            <!--    EVENTOS DE MASCOTAS    -->
            <!-- ========================= -->
            <VerticalStackLayout Spacing="12">

                <Label Text="Eventos de mascotas"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />

                <Button Text="➕ Crear evento de mascota"
                        Command="{Binding CreatePetEventCommand}"
                        BackgroundColor="#7D5FFF"
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="48" />

                <Label Text="No hay eventos de mascotas para este día"
                       FontSize="16"
                       TextColor="{StaticResource TextSecondary}"
                       IsVisible="{Binding NoPetEvents}" />

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
