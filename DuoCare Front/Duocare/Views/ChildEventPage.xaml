<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Duocare.Views.ChildEventPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#0B1726">

    <ScrollView>
        <VerticalStackLayout Padding="28" Spacing="28">

            <Label Text="Nuevo evento de niño"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Frame BackgroundColor="#112233"
                   CornerRadius="20"
                   Padding="24"
                   BorderColor="#7FB3D5">

                <VerticalStackLayout Spacing="22">

                    <VerticalStackLayout>
                        <Label Text="Tipo de evento"
                               TextColor="White"
                               FontAttributes="Bold" />
                        <Picker Title="Selecciona tipo"
                                ItemsSource="{Binding EventTypes}"
                                SelectedItem="{Binding SelectedEventType}"
                                TextColor="White" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Fecha"
                               TextColor="White"
                               FontAttributes="Bold" />
                        <DatePicker Date="{Binding Date}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Hora"
                               TextColor="White"
                               FontAttributes="Bold" />
                        <TimePicker Time="{Binding Time}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Lugar"
                               TextColor="White"
                               FontAttributes="Bold" />
                        <Entry Placeholder="Ej: Entrada principal del colegio"
                               Text="{Binding Location}"
                               PlaceholderColor="#8899AA"
                               TextColor="White" />
                    </VerticalStackLayout>

                    <VerticalStackLayout>
                        <Label Text="Notas"
                               TextColor="White"
                               FontAttributes="Bold" />
                        <Editor Placeholder="Ej: Llevar mochila"
                                Text="{Binding Notes}"
                                PlaceholderColor="#8899AA"
                                TextColor="White"
                                AutoSize="TextChanges" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Frame>

            <Button Text="Guardar evento"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#7FB3D5"
                    TextColor="Black"
                    CornerRadius="12"
                    HeightRequest="50" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
