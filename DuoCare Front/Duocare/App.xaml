<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Duocare.Converters"
             x:Class="Duocare.App">

    <Application.Resources>

        <ResourceDictionary>

            <!-- CONVERTERS -->
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:PasswordColorConverter x:Key="PasswordColorConverter" />
            <converters:PasswordIconConverter x:Key="PasswordIconConverter" />

            <!-- CONVERTERS DASHBOARD -->
            <converters:BoolToEmojiConverter x:Key="BoolToEmojiConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />

            <!-- COLORES PRIMERO, LUEGO ESTILOS -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>
